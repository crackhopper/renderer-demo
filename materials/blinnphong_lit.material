shader: blinnphong_0

variants:
  USE_LIGHTING: true

variantRules:
  - requires: [USE_NORMAL_MAP]
    depends: [USE_LIGHTING, USE_UV]
  - requires: [USE_SKINNING]
    depends: [USE_LIGHTING]

passes:
  Forward:
    renderState:
      cullMode: Back
      depthTest: true
      depthWrite: true

parameters:
  MaterialUBO.baseColor: [0.8, 0.8, 0.8]
  MaterialUBO.shininess: 12.0
  MaterialUBO.specularIntensity: 1.0
  MaterialUBO.enableAlbedo: 0
  MaterialUBO.enableNormal: 0
